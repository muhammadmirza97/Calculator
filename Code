num1 = float(input("Enter your 1st number:")) #Request for 1st number
num2 = float(input("Enter your 2nd number:")) #Request for 2nd number

print("Choose an operation: +, -, *, /") #Request for operation for the numbers
operation = input("Enter your choice:")

if operation == '+':
  result = num1 + num2
elif operation == '-':
  result = num1 - num2
elif operation == '*':
  result = num1 * num2
elif operation == '/':
  if num2 = 0:
    result = "Error! Cannot divide by 0. Change 2nd number to proceed"
  else:
    result = num1 / num2
else:
  result = "Invalid operation."

print(f"Result: {result}"}
